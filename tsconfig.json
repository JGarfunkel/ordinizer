{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@civillyengaged/ordinizer-core": ["packages/core/src"],
      "@civillyengaged/ordinizer-servercore": ["packages/servercore/src"]
    },
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*",
    "app/server/tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}