{
  "name": "ordinizer",
  "version": "1.0.0",
  "private": true,
  "description": "Ordinizer monorepo workspace",
  "type": "module",
  "workspaces": [
    "app",
    "app/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/servercore",
    "build:workspaces": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "dependencies": {
    "wouter": "^3.9.0"
  }
}
