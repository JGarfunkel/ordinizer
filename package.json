{
  "name": "ordinizer",
  "version": "1.0.0",
  "description": "A reusable library for municipal statute analysis and scoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./metadata": {
      "import": "./dist/metadata.js",
      "types": "./dist/metadata.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "npm exec -- tsc --project tsconfig.json",
    "dev": "npm exec -- tsc --watch --project tsconfig.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "municipal",
    "statute",
    "analysis",
    "policy",
    "ordinance",
    "scoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@pinecone-database/pinecone": "^6.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.60.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "express": "^4.21.2",
    "fs-extra": "^11.3.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "openai": "^5.12.2",
    "react": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.6.0",
    "wouter": "^3.3.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "^0.2.8",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@vitejs/plugin-react": "^4.3.2",
    "@types/node": "^20.16.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@types/node": "^18.0.0 || ^19.0.0 || ^20.0.0"
  }
}
