{
  "name": "@civillyengaged/ordinizer",
  "version": "1.0.0",
  "private": true,
  "description": "Ordinizer monorepo workspace",
  "publishConfig": { "access": "public" },
  "keywords": [
    "ordinance",
    "organizer"
  ],
  "homepage": "https://github.com/JGarfunkel/ordinizer#readme",
  "bugs": {
    "url": "https://github.com/JGarfunkel/ordinizer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JGarfunkel/ordinizer.git"
  },
  "license": "MIT",
  "author": "Jon Garfunkel",
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "app",
    "app/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/servercore",
    "build:workspaces": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.11",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
