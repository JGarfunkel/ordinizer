{
  "name": "@ordinizer/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Express API layer for the Ordinizer application",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test:mock-server": "ts-node ./tests/scripts/mockServer.ts",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:watch": "jest --watch --config jest.config.cjs"
  },
  "dependencies": {
    "@ordinizer/core": "file:../../packages/core",
    "@ordinizer/servercore": "file:../../packages/servercore",
    "express": "^4.21.2",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.16.11",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
