{
  "name": "@ordinizer/servercore",
  "version": "0.1.0",
  "description": "Shared server-side core utilities and scoring logic for Ordinizer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "node -e \"['dist','tsconfig.tsbuildinfo'].forEach(f=>require('fs').rmSync(f,{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@ordinizer/core": "file:../core",
    "fs-extra": "^11.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.16.11",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
