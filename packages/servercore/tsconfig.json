{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@civillyengaged/ordinizer-core": ["../core/src/index.ts"],
      "@ordinizer/core/*": ["../core/src/*"],
      "@civillyengaged/ordinizer-servercore": ["./src/index.ts"],
      "@ordinizer/servercore/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../core/tsconfig.json" }
  ]
}
