{
  "name": "@civillyengaged/ordinizer-core",
  "version": "1.0.1",
  "description": "Core types and utilities for the Ordinizer library",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "declaration": true,
  "declarationMap": true,
  "emitDeclarationOnly": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"['dist','tsconfig.tsbuildinfo'].forEach(f=>require('fs').rmSync(f,{recursive:true,force:true}))\""
  },
  "keywords": [
    "ordinizer",
    "municipal",
    "statutes",
    "types"
  ],
  "license": "MIT"
}
